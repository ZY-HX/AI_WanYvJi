# Backend runtime env (for deployment platform variables)
# Railway will inject PORT automatically, no need to set it manually.
DB_URL=jdbc:mysql://<host>:3306/english_learning_mate?useUnicode=true&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=<db_username>
DB_PASSWORD=<db_password>
JWT_SECRET=<long_random_secret>

# Optional: required only when using system AI key mode
AI_API_KEY=
